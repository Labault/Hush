{
  "name": "hush",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up",
    "dev:docker:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:clean": "docker compose -f docker-compose.dev.yml down -v",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "prod:build": "docker compose --env-file .env.prod -f docker-compose.prod.yml build",
    "prod:up": "docker compose --env-file .env.prod -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose --env-file .env.prod -f docker-compose.prod.yml down",
    "prod:logs": "docker compose --env-file .env.prod -f docker-compose.prod.yml logs -f",
    "prod:rebuild": "docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
