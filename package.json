{
  "name": "hush",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev": "npm-run-all -p dev:api dev:web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
